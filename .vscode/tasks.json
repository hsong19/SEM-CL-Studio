{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SEM-CL: Setup",
      "type": "process",
      "command": "uv",
      "args": [
        "sync"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "SEM-CL: Run",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "semcl-studio"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "SEM-CL: Setup",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "SEM-CL: Test",
      "type": "process",
      "command": "uv",
      "args": [
        "run",
        "pytest",
        "-q"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "SEM-CL: Setup",
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
